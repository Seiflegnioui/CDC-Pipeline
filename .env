# ── CDC Pipeline Environment Variables ──────────────────────────────────
# Copy this file to .env and adjust values as needed.

# MongoDB
MONGODB_PORT=27017
MONGO_INITDB_DATABASE=appdb

# Kafka (external host port)
KAFKA_EXTERNAL_PORT=29092

# Kafka Connect
CONNECT_PORT=8083

# Elasticsearch
ES_PORT=9200

# Kibana
KIBANA_PORT=5601

# Kafka UI
KAFKA_UI_PORT=8080
